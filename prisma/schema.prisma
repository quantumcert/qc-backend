// ===========================================================
// QUANTUM CERT — DIAMOND PATTERN UNIVERSAL CORE SCHEMA
// Architecture: EIP-2535 Faceted Diamond Pattern
// Version: 3.2.0 — Multi-Chain DLT Adapters & Escrow
// 
// GOLDEN RULE: 100% AGNOSTIC. No domain-specific terminology.
// Only universal terms: Tenant, Asset, Device, Event, Owner, Metadata.
// ===========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================
// PHASE 1: MULTI-TENANT ENGINE & ACCESS CONTROL
// ===========================================================

// --- TENANT — SaaS Client Isolation Unit -----------------
model Tenant {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  contactEmail String
  isActive     Boolean @default(true)
  status       TenantStatus @default(ACTIVE)
  activatedAt  DateTime?
  suspendedAt  DateTime?
  archivedAt   DateTime?
  statusReason String?

  planTier PlanTier @default(FREE)

  maxRequestsPerMinute Int?
  maxRequestsPerDay    Int?

  // --- Phase X: Dynamic Pricing -------------------------
  customTransferFee Float?
  customTagFee      Float?

  // DLT chain for anchor routing (used by DLTAdapterFactory)
  targetChain String @default("ALGORAND")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relations ----------------------------------------
  apiKeys              ApiKey[]
  rateLimitCounters    RateLimitCounter[]
  assets               Asset[] // Phase 2
  eventLogs            EventLog[] // Phase 4
  blindContactLogs     BlindContactLog[] // Phase 5
  webhooks             TenantWebhook[] // Phase 6: B2B Notifications
  escrows              Escrow[] // Multi-Chain Escrow
  chainTransactions    ChainTransaction[] // Multi-Chain Tx Logging
  pendingTransactions  PendingTransaction[] // Retry Worker Queue
  userWallets          UserWallet[] // Custodial deposit addresses
  tenantSecrets        TenantSecret[] // KMS-wrapped tenant-scoped secrets
  deposits             Deposit[] // Incoming stablecoin deposits
  agents               Agent[] // M2M / IoT Agent identities
  contributors         Contributor[] // Curation Layer — CORE-05
  pendingContributions PendingContribution[] // Curation Layer — CORE-06
  commercialProfile    TenantCommercialProfile?
  tenantUsers          TenantUser[]
  tenantMemberships    TenantMembership[]
  purchaseOrders       PurchaseOrder[]
  paymentIntents       PaymentIntent[]
  paymentEvents        PaymentEvent[]
  creditLedgerEntries  CreditLedgerEntry[]
  qTagLedgerEntries    QTagLedgerEntry[]
  qTagFulfillmentOrders QTagFulfillmentOrder[]
  migrationRuns        MigrationRun[]
  migrationCheckpoints MigrationCheckpoint[]
  migrationRecords     MigrationRecord[]

  @@index([slug])
  @@index([planTier])
  @@index([isActive])
  @@index([status])
}

enum PlanTier {
  FREE
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model TenantCommercialProfile {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  legalName       String?
  taxId           String?
  taxIdType       String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  billingOwner    String?
  commercialPlan  String?
  limits          Json    @default("{}")
  whiteLabel      Json    @default("{}")
  internalNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([taxId])
}

model TenantUser {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String?
  phone        String?
  document     String?
  documentType String?
  displayName  String?
  role         TenantUserRole   @default(MEMBER)
  status       TenantUserStatus @default(ACTIVE)

  legacyDashboardUserId String? @unique
  legacyOpenId          String? @unique
  profile               Json    @default("{}")
  metadata              Json    @default("{}")

  guardianId String?
  guardian   TenantUser?  @relation("TenantUserDependents", fields: [guardianId], references: [id])
  dependents TenantUser[] @relation("TenantUserDependents")

  externalIdentities ExternalIdentity[]
  memberships        TenantMembership[]
  invitedMemberships TenantMembership[] @relation("MembershipInviter")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  migratedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, document])
  @@index([tenantId, role])
  @@index([legacyDashboardUserId])
  @@index([legacyOpenId])
  @@index([guardianId])
}

enum TenantUserRole {
  PLATFORM_ADMIN
  TENANT_ADMIN
  OPERATOR
  MEMBER
  DEPENDENT
  VIEWER
}

enum TenantUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model ExternalIdentity {
  id           String @id @default(cuid())
  tenantUserId String
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)

  provider        String
  providerSubject String
  email           String?
  metadata        Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerSubject])
  @@index([tenantUserId])
  @@index([provider])
}

model TenantMembership {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   TenantMembershipRole   @default(MEMBER)
  status TenantMembershipStatus @default(ACTIVE)

  invitedByUserId String?
  invitedByUser   TenantUser? @relation("MembershipInviter", fields: [invitedByUserId], references: [id])
  reason          String?
  metadata        Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([userId])
  @@index([status])
}

enum TenantMembershipRole {
  PLATFORM_ADMIN
  TENANT_ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

enum TenantMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

// --- API KEY — Authenticated Access Credentials ---------
model ApiKey {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  keyHash   String     @unique
  keyPrefix String
  label     String?
  role      ApiKeyRole @default(READER)
  scopes    String[]   @default([])

  isActive   Boolean   @default(true)
  revokedAt  DateTime?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdByActorId String?
  revokedByActorId String?
  revocationReason String?
  rotatedFromApiKeyId String?
  lastRotatedAt DateTime?

  createdAt DateTime @default(now())

  // Back-reference for Agent — FK lives in Agent.apiKeyId, no extra column here
  agent Agent?

  @@index([tenantId])
  @@index([keyHash])
  @@index([keyPrefix])
  @@index([isActive])
  @@index([expiresAt])
  @@index([rotatedFromApiKeyId])
}

enum ApiKeyRole {
  ADMIN
  OPERATOR
  READER
}

// ═══════════════════════════════════════════════════════════
// AGENT — Machine Identity for M2M / IoT
// Separate from Device (NFC hardware). Agent is a software
// identity that authenticates via ApiKey + Falcon-512 signature.
// ═══════════════════════════════════════════════════════════
model Agent {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?

  // Falcon-512 public key in base64 — verifies payload signatures
  publicKeyFalcon  String
  // Selectors this agent is allowed to execute (e.g. ["event.recordAuthenticated"])
  allowedSelectors String[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FK to the ApiKey created at registration time (role: OPERATOR)
  apiKeyId String? @unique
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  @@index([tenantId, isActive])
}

// --- RATE LIMIT COUNTER ---------------------------------
model RateLimitCounter {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  windowType   RateLimitWindow
  windowKey    String
  requestCount Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, windowType, windowKey])
  @@index([tenantId, windowType])
  @@index([windowKey])
}

enum RateLimitWindow {
  MINUTE
  DAILY
}

// --- AUDIT LOG ------------------------------------------
model AuditLog {
  id           String  @id @default(cuid())
  tenantId     String?
  apiKeyPrefix String?

  action       String
  resourceType String
  resourceId   String?

  metadata  Json?
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([tenantId, timestamp])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([timestamp])
}

model AdminAuditLog {
  id String @id @default(cuid())

  tenantId      String?
  actorUserId   String?
  actorTenantId String?

  action       String
  resourceType String
  resourceId   String?
  reason       String?
  payloadHash  String?
  metadata     Json?

  correlationId String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorTenantId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([correlationId])
}

model ApiRequestAudit {
  id String @id @default(cuid())

  tenantId     String
  apiKeyId     String?
  keyPrefix    String?
  role         String?
  method       String
  path         String
  selector     String?
  statusCode   Int
  latencyMs    Int?
  correlationId String?
  sanitizedError String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([keyPrefix])
  @@index([statusCode])
  @@index([correlationId])
  @@index([selector])
}

// ===========================================================
// PHASE 2: AGNOSTIC ASSET ENGINE & ZERO KNOWLEDGE SECURITY
// ===========================================================

// --- ASSET — The Universal Agnostic Container -----------
// The Asset is a 100% agnostic container. It stores only
// structural identifiers and a FREE-FORM JSON payload.
// The Tenant injects whatever data structure they need
// into the metadata field.
//
// Design: Prepared for future FractionalOwnershipFacet
// and FungibleFacet via dedicated fields.
model Asset {
  id String @id @default(cuid())

  // --- Phase 5: Asset Status Machine --------------------
  status AssetStatus @default(ACTIVE)

  // --- Tenant Isolation ---------------------------------
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // --- Immutable Core Identifiers -----------------------
  // externalId: Tenant-provided external reference (e.g., SKU, serial)
  // Must be unique within the Tenant scope.
  externalId String?

  // --- Hardware Binding (optional — for physical assets) -
  // Links this asset to a physical NFC/QTag Device.
  // null = purely digital asset (no hardware).
  deviceId String? @unique
  device   Device? @relation(fields: [deviceId], references: [id])

  // --- Free-Form Metadata (HEART OF THE ASSET) ---------
  // This JSON field is 100% owned by the Tenant.
  // The platform NEVER interprets its contents.
  // The Tenant can store ANY structure they need.
  metadata Json @default("{}")

  // --- Phase 3: Public Profile & Privacy Control --------
  // Public, unique, and persistent URL for QR Payload / Open Read
  publicUrl      String   @unique
  // Which keys in the `metadata` JSON are exposed publicly
  publicDataKeys String[] @default([])

  // --- Ownership ----------------------------------------
  // Multi-owner support via Owner junction table.
  owners Owner[]

  // --- Phase 4: Event Engine & Quarantine ---------------
  events EventLog[]

  // --- Phase 5: Double-Blind Quarantine -----------------
  blindContactLogs BlindContactLog[]

  // --- Phase 6: ESG Provenance (Ancestry Tracking) ------
  parentAssetId String?
  parentAsset   Asset?  @relation("AssetToAsset", fields: [parentAssetId], references: [id])
  childAssets   Asset[] @relation("AssetToAsset")

  // --- Phase 6: Audit & Telemetry -----------------------
  tagScanLogs TagScanLog[]
  qTagFulfillmentOrders QTagFulfillmentOrder[]

  // --- FractionalOwnershipFacet Preparation -------------
  // Enables future fractional ownership (e.g., 40% Owner A, 60% Owner B).
  // false = standard single/multi-owner mode
  // true  = ownership percentages tracked in Owner.sharePercent
  isFractionable Boolean @default(false)

  // --- FungibleFacet Preparation ------------------------
  // Enables future fungible token emission.
  // false = unique/non-fungible asset (1:1)
  // true  = fungible (1:N, tracked by totalSupply)
  isFungible        Boolean @default(false)
  totalSupply       Int? // Only set when isFungible=true
  circulatingSupply Int? // Minted so far (fungible mode)

  // --- Lifecycle ----------------------------------------
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, externalId]) // externalId unique per Tenant
  @@index([tenantId])
  @@index([deviceId])
  @@index([isFractionable])
  @@index([isFungible])
  @@index([createdAt])
}

// --- OWNER — Multi-Owner Relationship -------------------
// Junction table linking Assets to their Owners.
// Supports co-ownership and fractional ownership.
//
// ownerRef: A universal reference string identifying the owner.
//   It can be a wallet address, an email hash, an external user ID,
//   or any unique identifier the Tenant uses.
//   The platform does NOT enforce the format — it is Tenant-controlled.
model Owner {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // --- Owner Identification -----------------------------
  // Universal owner reference — format defined by the Tenant.
  ownerRef String

  // Document-based identification (CPF/CNPJ for legal chain of custody)
  document     String? // digits only, no mask (e.g. "12345678909")
  documentType String? // 'CPF' | 'CNPJ'

  // --- Optional Display / Contact -----------------------
  label String? // Human-readable label (e.g., "Primary Owner")

  // --- FractionalOwnershipFacet Fields ------------------
  // Only used when Asset.isFractionable = true.
  // Represents the percentage share (0.00 to 100.00).
  sharePercent Decimal? @db.Decimal(6, 2)

  // --- Ownership Lifecycle ------------------------------
  acquiredAt DateTime  @default(now())
  revokedAt  DateTime? // null = active owner

  @@unique([assetId, ownerRef]) // One owner entry per ownerRef per Asset
  @@index([assetId])
  @@index([ownerRef])
  @@index([assetId, document])
}

// --- DEVICE — Hardware State & Anti-Replay Guardian -----
// Tracks the physical lifecycle of an NFC/QTag chip.
// Stores the monotonic counter for Replay Attack protection.
//
// CRITICAL SECURITY RULE:
//   The lastCounter field is the SINGLE SOURCE OF TRUTH.
//   Any NFC reading with counter <= lastCounter is REJECTED
//   as a cloning/replay attempt. The counter can ONLY advance.
model Device {
  id String @id @default(cuid())

  // --- Hardware Identifier ------------------------------
  // The UID is the unique hardware identifier burned into
  // the NFC chip during manufacturing. It is immutable.
  uid String @unique // e.g., "04A1B2C3D4E5F6" (NTAG 424 DNA UID)

  // --- Tenant Scope -------------------------------------
  tenantId String

  // --- Anti-Replay Monotonic Counter --------------------
  // This is the LAST VALID counter value read from this chip.
  // Atomically updated on each valid NFC tap.
  // RULE: incoming CTR must be STRICTLY GREATER than this value.
  lastCounter Int @default(0)

  // --- Tap Audit Trail ----------------------------------
  lastTapAt DateTime? // Timestamp of last valid NFC tap
  totalTaps Int       @default(0) // Lifetime tap count
  lastTapIp String? // IP of last reader (audit)
  lastLat   Float? // Last tap latitude (for Haversine)
  lastLon   Float? // Last tap longitude (for Haversine)

  // --- SDM Key References (wrapped ciphertext, never plaintext) ----
  sdmMacKeyId String? // KMS-wrapped AES-128 for tap CMAC validation
  sdmEncKeyId String? // KMS-wrapped AES-128 for picc_data decryption

  // --- Device State -------------------------------------
  status       DeviceStatus @default(ACTIVE)
  isActive     Boolean  @default(true)
  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // --- Zero-Knowledge Master Key ------------------------
  masterKey Json? // Stored encrypted via CryptoService

  // --- Reverse Relation ---------------------------------
  asset Asset? // The asset linked to this device (if any)

  // --- Tap History --------------------------------------
  tapLog DeviceTapLog[]

  @@index([uid])
  @@index([tenantId])
  @@index([isActive])
  @@index([status])
}

enum DeviceStatus {
  PROVISIONED
  ACTIVE
  DISABLED
  REPLACED
}

// --- DEVICE TAP LOG — Immutable NFC Tap History ---------
// Every NFC tap (valid or rejected) is logged here for
// audit, forensics, and fraud detection.
model DeviceTapLog {
  id String @id @default(cuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // --- Tap Data -----------------------------------------
  counterValue Int // The CTR value received
  cmacReceived String // The CMAC transmitted by the chip
  cmacValid    Boolean // Did the CMAC pass cryptographic validation?

  // --- Verdict ------------------------------------------
  verdict TapVerdict // VALID, REPLAY_BLOCKED, CMAC_INVALID, DEVICE_INACTIVE

  // --- Request Context ----------------------------------
  ipAddress String?
  userAgent String?
  rawUrl    String? // The full NFC URL for forensic analysis

  timestamp DateTime @default(now())

  @@index([deviceId, timestamp])
  @@index([verdict])
  @@index([timestamp])
}

enum TapVerdict {
  VALID // CTR > lastCounter AND CMAC valid
  REPLAY_BLOCKED // CTR <= lastCounter (cloning attempt)
  CMAC_INVALID // CMAC signature mismatch
  DEVICE_INACTIVE // Device exists but is deactivated
  DEVICE_NOT_FOUND // UID not registered in the system
  RELAY_ATTACK // Distance bounding / relay attack detected
}

// ===========================================================
// PHASE 4: ATTESTATION ENGINE, EVENTS & QUARANTINE
// ===========================================================

// --- EVENT LOG — Chronological Asset Attachments --------
// Events append data/milestones to an Asset's history.
// Supports direct (APPROVED) or quarantined (PENDING) writes.
model EventLog {
  id String @id @default(cuid())

  wasteLogs WasteLog[]

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Origin can be the ApiKey ID (for authenticated) or "PUBLIC" (for unauthenticated)
  origin String

  // Track the exact API Key or ID that created this event (crucial for EXPERT/AUDITOR tracing)
  issuerId String?

  status EventStatus @default(PENDING)

  // Opaque payload containing the event's facts
  payload Json @default("{}")

  // For future Phase 6 integration
  signatureHash String?
  dltTxId       String?

  // Sub-sistema 3: SHA3-512 of the physical document (PDF, report, contract)
  documentHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([documentHash])
  @@unique([tenantId, documentHash])
  @@index([status, dltTxId]) // RED TEAM HOTFIX 5: Anti-OOM Full Table Scan Lock
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  PENDING_FUNDS // For Queue
}

// ===========================================================
// PHASE 5: STATUS MANAGEMENT & DOUBLE-BLIND QUARANTINE
// ===========================================================

enum AssetStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
  BURNED
  AWAITING_PAYMENT
  LOCKED_IN_ESCROW
  // Legacy states — kept for backward compat with existing records
  ALERT
  INACTIVE
}

// --- BLIND CONTACT LOG — Finder's Quarantine ------------
// Double-blind privacy zone for assets in ALERT status.
model BlindContactLog {
  id String @id @default(cuid())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // JSON payload preserving the "Finder's" contact details
  contactData Json

  // Audit properties (Never exposed publicly, nor committed to DLT)
  originIp  String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([tenantId])
  @@index([createdAt])
}

// ===========================================================
// MULTI-CHAIN: ESCROW & CROSS-CHAIN TRANSACTION LOGGING
// ===========================================================

// --- ESCROW — Cross-Chain Escrow Record -----------------
model UserWallet {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Public DLT address generated by KMSService (HD derivation or account index)
  address String

  // Chain enum matching SupportedChain
  chain String // 'ETHEREUM' | 'POLYGON' | 'SOLANA' | 'STELLAR' | 'ALGORAND'

  // Falcon-512 public key (Base64) linked to this wallet for Triple-Sig
  pqcPublicKey String?

  // Account index used in HD derivation (if applicable)
  accountIndex Int @default(0)

  // --- PQC Key Wrapping (Phase 2) ---
  // Encrypted private key (AES-256-GCM wrapped by Master Falcon Key)
  // Null for watch-only or externally-managed wallets
  encryptedPrivateKey String?

  // Version of the key wrapping protocol (for migration/compatibility)
  keyWrapVersion Int @default(1)

  // When the key was last wrapped/rotated
  wrappedAt DateTime?

  // --- Circuit Breaker (Phase 2) ---
  // Individual wallet pause flag (overrides global circuit breaker)
  isPaused Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deposits Deposit[]

  @@unique([tenantId, address, chain])
  @@index([tenantId])
  @@index([address])
  @@index([chain])
}

// --- DEPOSIT --- Incoming stablecoin deposit log ------------
model Deposit {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Link to the receiving wallet
  walletId String
  wallet   UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // On-chain transaction hash
  txHash String @unique

  // Amount in smallest denomination (wei, microAlgos, etc.)
  amount String

  // Currency / token symbol
  currency String // 'USDC' | 'USDT' | 'USDC.e' | etc.

  // Token contract address or ASA ID
  assetAddress String?

  // Chain where the deposit occurred
  chain String

  // Block number where the transaction was mined
  blockNumber String?

  // Number of confirmations received
  confirmations Int @default(0)

  // Confirmation threshold required for this chain
  requiredConfirmations Int @default(12)

  // Deposit lifecycle
  status DepositStatus @default(PENDING)

  // When the deposit was first detected
  detectedAt DateTime @default(now())

  // When it reached required confirmations
  confirmedAt DateTime?

  // Raw on-chain metadata (logs, events, etc.)
  metadata Json?

  @@index([tenantId])
  @@index([walletId])
  @@index([txHash])
  @@index([status])
  @@index([chain])
  @@index([detectedAt])
}

enum DepositStatus {
  PENDING
  CONFIRMED
  FAILED
}

model PurchaseOrder {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId          String?
  type            PurchaseOrderType
  status          PurchaseOrderStatus @default(DRAFT)
  sku             String?
  quantity        Int @default(1)
  amount          String?
  currency        String?
  provider        String?
  providerOrderId String?
  metadata        Json @default("{}")

  createdByActorId String?
  reason           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentIntents      PaymentIntent[]
  paymentEvents       PaymentEvent[]
  creditLedgerEntries CreditLedgerEntry[]
  qTagLedgerEntries   QTagLedgerEntry[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([provider, providerOrderId])
  @@index([createdAt])
}

enum PurchaseOrderType {
  CREDIT_PACKAGE
  QTAG_PACKAGE
  ACTIVATION
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  CANCELLED
  REFUNDED
  FAILED
}

model PaymentIntent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  provider         String
  providerIntentId String?
  amount           String
  currency         String
  status           PaymentStatus @default(PENDING)
