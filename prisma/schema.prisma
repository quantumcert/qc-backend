// ===========================================================
// MASTER KEY — Post-Quantum Master Key Registry
// ===========================================================
// CRITICAL SECURITY: This model NEVER stores private keys.
// It only tracks metadata about the master Falcon-512 key
// which is stored in the HSM/Vault (or .env in dev).
// The actual key material is managed exclusively by KMSService.
// ===========================================================
model MasterKey {
  id String @id @default(cuid())

  // Key type discriminator (e.g., 'FALCON-512-MASTER', 'AES-256-MASTER')
  keyType String

  // SHA3-512 hash of the public key (for verification, never the private key)
  publicKeyHash String @unique

  // Version of the key wrapping protocol
  keyWrapVersion Int @default(1)

  // Whether this master key is currently active
  isActive Boolean @default(true)

  // When the key was created
  createdAt DateTime @default(now())

  // When the key was last rotated (null = never rotated)
  rotatedAt DateTime?

  // Audit metadata (rotation reason, etc.)
  metadata Json?

  @@index([keyType])
  @@index([isActive])
}

model TenantSecret {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  purpose String
  keyType String @default("FALCON-512")
  encryptedSecret String
  publicKeyB64 String?
  keyWrapVersion Int @default(1)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rotatedAt DateTime?

  @@unique([tenantId, purpose])
  @@index([tenantId])
  @@index([purpose])
  @@index([isActive])
}

// ===========================================================
// PANIC LOG — Security Watchdog & Circuit Breaker Audit
// ===========================================================
model PanicLog {
  id String @id @default(cuid())

  // Reason for the panic trigger
  reason String

  // Who or what triggered the panic (service name, admin ID, etc.)
  triggeredBy String?

  // Which chain was affected ('ALL', 'POLYGON', 'ETHEREUM', etc.)
  chainScope String @default("ALL")

  // Whether the panic has been resolved
  isResolved Boolean @default(false)

  // When the panic was triggered
  triggeredAt DateTime @default(now())

  // When the panic was resolved (null = still active)
  resolvedAt DateTime?

  // Resolution notes
  resolutionNotes String?

  // Raw metadata (anomaly scores, tx volumes, etc.)
  metadata Json?

  @@index([triggeredAt])
  @@index([isResolved])
  @@index([chainScope])
}

// --- ESCROW --- Cross-Chain Escrow Record -----------------
model Escrow {
  id String @id @default(cuid())

  // --- Tenant Isolation ---------------------------------
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- Correlation --------------------------------------
  escrowId String  @unique // Off-chain unique identifier
  assetId  String? // Optional link to Asset

  // --- Chain Identification -----------------------------
  chain     String // 'ETHEREUM' | 'SOLANA' | 'STELLAR' | 'ALGORAND'
  chainTxId String? // On-chain transaction ID

  // --- Parties ------------------------------------------
  sender   String // Wallet address (chain-native format)
  receiver String // Wallet address (chain-native format)

  // --- Financials ---------------------------------------
  amount       String // Stored as string to avoid precision loss
  assetAddress String? // Token contract address (null for native)

  // --- Time-Lock ----------------------------------------
  unlockTimestamp DateTime? // When escrow becomes releasable
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // --- Status -------------------------------------------
  status EscrowStatus @default(PENDING)

  // --- Release Control ----------------------------------
  releaseMode        String    @default("AUTO") // 'AUTO' | 'MANUAL'
  releaseConfirmedAt DateTime? // audit timestamp for manual releases

  // --- Audit --------------------------------------------
  metadata Json? // Chain-specific metadata

  @@index([tenantId])
  @@index([chain])
  @@index([status])
  @@index([escrowId])
  @@index([createdAt])
}

enum EscrowStatus {
  PENDING
  ACTIVE
  PROCESSING // atomic lock used by EscrowReleaseWorker
  RELEASED
  CANCELLED
  EXPIRED
}

// --- CHAIN TRANSACTION — Universal Cross-Chain Tx Log ---
model ChainTransaction {
  id String @id @default(cuid())

  // --- Tenant Isolation ---------------------------------
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- Correlation --------------------------------------
  txRef String // Off-chain correlation ID

  // --- Chain Identification -----------------------------
  chain     String // 'ETHEREUM' | 'SOLANA' | 'STELLAR' | 'ALGORAND'
  direction String // 'SEND' | 'RECEIVE' | 'ESCROW_CREATE' | 'ESCROW_RELEASE' | 'ESCROW_CANCEL' | 'ANCHOR'

  // --- On-Chain Data ------------------------------------
  fromAddress  String?
  toAddress    String?
  amount       String?
  assetAddress String? // Token contract address
  chainTxId    String?
  blockNumber  String?
  confirmedAt  DateTime?

  // --- Status -------------------------------------------
  status String @default("PENDING") // PENDING | CONFIRMED | FAILED

  // --- Audit --------------------------------------------
  metadata  Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([chain])
  @@index([txRef])
  @@index([status])
  @@index([createdAt])
}

// ===========================================================
// PHASE 4.5: MULTI-CHAIN RETRY WORKER (Pending Transactions)
// ===========================================================

// --- PENDING TRANSACTION — Retry Queue for DLT Operations -
// Stores failed or retryable blockchain operations.
// Processed by RetryWorker with exponential backoff.
// After max retries, moved to DLQ (Dead Letter Queue).
model PendingTransaction {
  id String @id @default(cuid())

  // --- Tenant Isolation ---------------------------------
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // --- Correlation --------------------------------------
  txRef String // Off-chain correlation ID (e.g., eventLog.id or escrowId)

  // --- Operation Type -----------------------------------
  txType PendingTxType // ANCHOR | ESCROW_CREATE | ESCROW_RELEASE | ESCROW_CANCEL | TRANSFER

  // --- Chain Identification -----------------------------
  chain String // 'ETHEREUM' | 'SOLANA' | 'STELLAR' | 'ALGORAND' | 'POLYGON'

  // --- Payload ------------------------------------------
  // Serialized parameters for the DLT operation
  payload Json

  // --- Retry Management ---------------------------------
  status       PendingTxStatus @default(PENDING)
  attemptCount Int             @default(0)
  maxAttempts  Int             @default(5)
  nextRetryAt  DateTime? // Scheduled time for next attempt
  lastError    String? // Last error message

  // --- DLQ (Dead Letter Queue) --------------------------
  isDlq     Boolean   @default(false)
  dlqReason String? // Reason for moving to DLQ
  dlqAt     DateTime?

  // --- Success Tracking ---------------------------------
  chainTxId   String? // On-chain tx hash after success
  confirmedAt DateTime?

  // --- Audit --------------------------------------------
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([chain])
  @@index([txType])
  @@index([nextRetryAt])
  @@index([isDlq])
  @@index([status, nextRetryAt]) // For retry worker query
}

enum PendingTxStatus {
  PENDING // Waiting for first attempt
  PROCESSING // Currently being processed
  FAILED // Failed, will retry
  SUCCESS // Completed successfully
  DLQ // Max retries exceeded
}

enum PendingTxType {
  ANCHOR
  ESCROW_CREATE
  ESCROW_RELEASE
  ESCROW_CANCEL
  TRANSFER
}

