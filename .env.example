# ═══════════════════════════════════════════════════════════
# QUANTUM CERT — DIAMOND PATTERN ENVIRONMENT VARIABLES
# Architecture: EIP-2535 Faceted Diamond Pattern
# Phase 1: Multi-Tenant Engine & Access Control
# ═══════════════════════════════════════════════════════════
#
# Copy to `.env` and fill with real values.
#
# Legend:
#   [REQUIRED]  — App will crash or fail without it
#   [OPTIONAL]  — Has sensible defaults
#   [SECURITY]  — Sensitive value, never commit to git
# ═══════════════════════════════════════════════════════════

# ─── CORE: DATABASE ─────────────────────────────────────
# [REQUIRED] [SECURITY] PostgreSQL connection URL
DATABASE_URL="postgresql://user:password@localhost:5432/quantum_cert?schema=public"

# ─── CORE: SERVER ───────────────────────────────────────
# [OPTIONAL] Default: 3000
PORT=3000
# [OPTIONAL] Allowed: development | production | test
NODE_ENV="development"

# ─── FRONTEND: CORS ─────────────────────────────────────
# [OPTIONAL] Frontend URL for CORS origin
FRONTEND_URL="http://localhost:5173"

# ═══════════════════════════════════════════════════════════
# PHASE 2+ VARIABLES (Placeholder — uncomment when needed)
# ═══════════════════════════════════════════════════════════

# ─── HARDWARE: NFC (NTAG 424 DNA) — Phase 2 ────────────
# NTAG_SUN_KEY="00000000000000000000000000000000"

# ─── BLOCKCHAIN: ALGORAND — Phase 6 ────────────────────
# ALGORAND_NETWORK="testnet"
# ALGORAND_ALGOD_SERVER="https://testnet-api.algonode.cloud"
# ALGORAND_ALGOD_TOKEN=""
# ALGORAND_QC_ACCOUNT_MNEMONIC=""

# ─── CRYPTO: FALCON-512 (Post-Quantum) — Phase 6 ──────
# FALCON_ENCRYPTION_KEY=""

# ── Sub-sistema 1: Core Gap Closure ──────────────────────────
# [REQUIRED] MercadoPago webhook HMAC secret (required for /api/v1/webhooks/mercadopago)
MP_WEBHOOK_SECRET=

# [OPTIONAL] AnchorQueueService cron interval in seconds (default: 30)
ANCHOR_QUEUE_INTERVAL_SECONDS=30

# API Documentation — chave pré-preenchida no Scalar em desenvolvimento
# Deixe vazio em produção. Gere uma chave via POST /api/v1/api-keys.
DOCS_DEFAULT_API_KEY=qc_sua_chave_dev_aqui
